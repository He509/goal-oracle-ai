<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GOAL ORACLE AI</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=Exo+2:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://gumroad.com/js/gumroad.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Assistant:wght@400;700;800&family=Cinzel:wght@700&display=swap');

*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#0a0a0f;--bg2:#111118;--bg3:#1a1a25;--bg4:#222233;
--gold:#d4a528;--gold2:#f0c94d;--gold3:#b8941e;--gold-dim:rgba(212,165,40,.15);
--gold-glow:rgba(212,165,40,.3);--text:#e8e8f0;--text2:#9999aa;--text3:#666678;
--green:#22c55e;--red:#ef4444;--blue:#3b82f6;
--card-radius:16px;--transition:all .3s cubic-bezier(.4,0,.2,1);
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;overflow-x:hidden;min-height:100vh}

body::before{content:'';position:fixed;inset:0;background:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9999}

.pitch-bg{position:fixed;inset:0;overflow:hidden;z-index:0}
.pitch-bg svg{position:absolute;width:100%;height:100%;opacity:.04}

/* HEADER */
header{position:sticky;top:0;z-index:100;background:rgba(10,10,15,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(212,165,40,.12);padding:0 40px;height:72px;display:flex;align-items:center;justify-content:space-between}
.logo{display:flex;align-items:center;gap:16px}

/* ---- SOCCER BALL LOGO ICON ---- */
.logo-icon{width:48px;height:48px;border:2px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;animation:pulse-glow 3s ease-in-out infinite;overflow:hidden}
.logo-icon::after{content:'';position:absolute;inset:-4px;border:1px solid rgba(212,165,40,.2);border-radius:50%;animation:spin 20s linear infinite}
.logo-icon svg{animation:spin 8s linear infinite;filter:drop-shadow(0 0 6px rgba(212,165,40,.6))}

@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse-glow{0%,100%{box-shadow:0 0 10px rgba(212,165,40,.2)}50%{box-shadow:0 0 25px rgba(212,165,40,.4)}}

.logo-text{font-family:'Orbitron',sans-serif;font-weight:800;font-size:18px;color:var(--gold);letter-spacing:3px;line-height:1.2}
.logo-text span{display:block;font-size:12px;font-weight:500;letter-spacing:5px;color:var(--gold3)}

nav{display:flex;gap:32px;align-items:center}
nav a{color:var(--text2);text-decoration:none;font-family:'Exo 2',sans-serif;font-weight:500;font-size:14px;letter-spacing:1.5px;text-transform:uppercase;transition:var(--transition);position:relative;padding:4px 0}
nav a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:var(--gold);transition:var(--transition)}
nav a:hover{color:var(--gold)}
nav a:hover::after{width:100%}
nav a.active{color:var(--gold)}
nav a.active::after{width:100%}
nav a.nav-pro-btn{
  background:linear-gradient(135deg,rgba(201,168,76,0.12),rgba(201,168,76,0.05));
  border:1px solid rgba(201,168,76,0.45);
  border-radius:8px;
  padding:6px 16px !important;
  color:#e8d08c !important;
  font-weight:700;
  animation:pro-btn-glow 2.5s ease-in-out infinite;
  position:relative;overflow:hidden;
}
nav a.nav-pro-btn::after{display:none}
nav a.nav-pro-btn:before{
  content:'';position:absolute;top:0;left:-100%;width:55%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,240,150,0.2),transparent);
  animation:pro-btn-sweep 2.5s ease-in-out infinite;
}
@keyframes pro-btn-glow{
  0%,100%{box-shadow:0 0 8px rgba(201,168,76,0.2)}
  50%{box-shadow:0 0 20px rgba(201,168,76,0.5)}
}
@keyframes pro-btn-sweep{0%{left:-100%}65%,100%{left:160%}}

.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px}
.hamburger span{width:24px;height:2px;background:var(--gold);transition:var(--transition)}

/* Login button */
.nav-login{
  display:flex;align-items:center;gap:7px;
  padding:7px 16px;border-radius:8px;cursor:pointer;
  border:1px solid rgba(255,255,255,0.12);
  background:rgba(255,255,255,0.04);
  font-family:'Exo 2',sans-serif;font-size:11px;font-weight:600;
  letter-spacing:1.5px;text-transform:uppercase;color:#8a8d9a;
  transition:all .2s;white-space:nowrap;
}
.nav-login:hover{border-color:rgba(255,255,255,0.25);color:#c8c9d0}
@media(max-width:768px){.nav-login{display:none}}

/* How It Works page */
.hiw-page{position:relative;z-index:1;max-width:900px;margin:0 auto;padding:60px 24px 80px}
.hiw-header{text-align:center;margin-bottom:48px}
.hiw-eyebrow{font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:5px;color:#5a5d6a;text-transform:uppercase;margin-bottom:12px}
.hiw-title{font-family:'Cinzel',serif;font-weight:900;font-size:40px;letter-spacing:9px;text-transform:uppercase;background:linear-gradient(180deg,#fff5c0,#e8d08c,#c9a84c,#a07c2a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:14px;animation:dbt-glow 3s ease-in-out infinite}
.hiw-sub{font-family:'Exo 2',sans-serif;font-size:14px;color:#5a5d6a;letter-spacing:1px}
.hiw-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:48px}
.hiw-step{border-radius:16px;padding:24px 18px;text-align:center;position:relative}
.hiw-step-1{background:linear-gradient(160deg,#09090f,#0c0e1c);border:1px solid rgba(201,168,76,0.25)}
.hiw-step-2{background:linear-gradient(160deg,#09090f,#0c0e1c);border:1px solid rgba(99,102,241,0.25)}
.hiw-step-3{background:linear-gradient(160deg,#09090f,#0c0e1c);border:1px solid rgba(34,197,94,0.2)}
.hiw-step-4{background:linear-gradient(160deg,#09090f,#0c0e1c);border:1px solid rgba(201,168,76,0.45);box-shadow:0 0 40px rgba(201,168,76,0.1)}
.hiw-num{font-family:'Orbitron',sans-serif;font-size:32px;font-weight:900;margin-bottom:10px;line-height:1}
.hiw-step-1 .hiw-num{color:rgba(201,168,76,0.35)}
.hiw-step-2 .hiw-num{color:rgba(99,102,241,0.35)}
.hiw-step-3 .hiw-num{color:rgba(34,197,94,0.3)}
.hiw-step-4 .hiw-num{color:rgba(201,168,76,0.6)}
.hiw-icon{font-size:32px;margin-bottom:12px}
.hiw-name{font-family:'Orbitron',sans-serif;font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px}
.hiw-step-1 .hiw-name{color:#c9a84c}
.hiw-step-2 .hiw-name{color:#818cf8}
.hiw-step-3 .hiw-name{color:#22c55e}
.hiw-step-4 .hiw-name{color:#e8d08c}
.hiw-desc{font-size:12px;color:#5a5d6a;line-height:1.7}
.hiw-arrow{position:absolute;right:-10px;top:44%;font-size:20px;color:rgba(201,168,76,0.2);z-index:2}
.hiw-step:last-child .hiw-arrow{display:none}
@media(max-width:768px){
.hiw-steps{grid-template-columns:1fr 1fr}
.hiw-title{font-size:26px;letter-spacing:5px}
.hiw-arrow{display:none}
}

/* FAQ */
.faq-section{max-width:760px;margin:0 auto 40px;padding:0 24px}
.faq-sec-header{text-align:center;margin-bottom:28px}
.faq-sec-eyebrow{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:5px;color:#5a5d6a;text-transform:uppercase;margin-bottom:10px}
.faq-sec-title{font-family:'Cinzel',serif;font-weight:900;font-size:28px;letter-spacing:6px;text-transform:uppercase;background:linear-gradient(180deg,#fff5c0,#c9a84c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.faq-items{display:flex;flex-direction:column;gap:10px}
.faq-item{border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.06);background:#08090f;transition:border-color .2s}
.faq-item.open{border-color:rgba(201,168,76,0.2);background:#0a0c18}
.faq-q{padding:16px 20px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;gap:12px;user-select:none}
.faq-q-text{font-size:13px;font-weight:600;color:#c8c9d0;letter-spacing:.5px}
.faq-item.open .faq-q-text{color:#e8d08c}
.faq-chevron{font-size:11px;color:#5a5d6a;transition:transform .3s;flex-shrink:0}
.faq-item.open .faq-chevron{transform:rotate(180deg);color:#c9a84c}
.faq-a{padding:0 20px 16px;font-size:12px;color:#5a5d6a;line-height:1.8;display:none}
.faq-item.open .faq-a{display:block}
a.logo-pro-tag{
  display:flex;align-items:center;gap:5px;
  background:linear-gradient(135deg,rgba(201,168,76,0.12),rgba(201,168,76,0.05));
  border:1px solid rgba(201,168,76,0.45);border-radius:6px;
  padding:3px 10px;font-family:'Orbitron',sans-serif;
  font-size:9px;font-weight:700;letter-spacing:1.5px;color:#e8d08c;
  cursor:pointer;animation:pro-tag-glow 2.5s ease-in-out infinite;white-space:nowrap;
  text-decoration:none;
}
@keyframes pro-tag-glow{0%,100%{box-shadow:0 0 6px rgba(201,168,76,0.2)}50%{box-shadow:0 0 16px rgba(201,168,76,0.5)}}

/* Mobile overlay */
.mob-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);z-index:200}
.mob-overlay.open{display:block}

/* Mobile panel */
.mob-panel{position:fixed;top:0;right:-280px;bottom:0;width:260px;background:linear-gradient(160deg,#0a0c18,#0d1025);border-left:1px solid rgba(201,168,76,0.2);z-index:201;transition:right 0.3s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column}
.mob-panel.open{right:0}
.mob-panel-header{padding:18px 16px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:space-between}
.mob-panel-title{font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:3px;color:#c9a84c;text-transform:uppercase}
.mob-close{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:11px;color:#5a5d6a;cursor:pointer}
.mob-links{display:flex;flex-direction:column;flex:1;padding:8px 0}
.mob-link{display:flex;align-items:center;gap:12px;padding:14px 20px;color:#7a7d8a;font-family:'Exo 2',sans-serif;font-size:13px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.04);cursor:pointer;text-decoration:none;transition:all .2s}
.mob-link:last-child{border-bottom:none}
.mob-link.active{color:#e8d08c;background:rgba(201,168,76,0.05)}
.mob-dot{width:5px;height:5px;border-radius:50%;background:rgba(201,168,76,0.25);flex-shrink:0}
.mob-link.active .mob-dot{background:#c9a84c;box-shadow:0 0 6px rgba(201,168,76,0.5)}
.mob-pro-btn{margin:14px 12px;border-radius:10px;padding:14px;background:#07090a;outline:2px solid rgba(201,168,76,0.6);display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;animation:mob-pro-glow 2s ease-in-out infinite}
.mob-pro-btn span{font-family:'Exo 2',sans-serif;font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;background:linear-gradient(180deg,#fff5c0,#e8d08c,#c9a84c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 6px rgba(201,168,76,0.8))}
.mob-pro-btn::after{content:'';position:absolute;top:0;left:-100%;width:55%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,240,150,0.15),transparent);animation:mob-sweep 2.5s ease-in-out infinite}
@keyframes mob-sweep{0%{left:-100%}65%,100%{left:160%}}
@keyframes mob-pro-glow{0%,100%{outline-color:rgba(201,168,76,0.4);box-shadow:0 0 8px rgba(201,168,76,0.1)}50%{outline-color:rgba(201,168,76,1);box-shadow:0 0 20px rgba(201,168,76,0.35)}}

/* Cookie Banner */
.cookie-banner{position:fixed;bottom:0;left:0;right:0;z-index:999;background:linear-gradient(135deg,#0a0c18,#0d1025);border-top:1px solid rgba(201,168,76,0.25);padding:16px 32px;display:flex;align-items:center;justify-content:space-between;gap:20px;box-shadow:0 -4px 30px rgba(0,0,0,0.4);flex-wrap:wrap}
.cookie-text{font-family:'Exo 2',sans-serif;font-size:12px;color:#6a6d7a;line-height:1.6;flex:1;min-width:200px}
.cookie-text a{color:#c9a84c;text-decoration:none}
.cookie-btns{display:flex;gap:10px;flex-shrink:0}
.cookie-btn-accept{padding:9px 20px;border-radius:8px;border:none;cursor:pointer;background:#07090a;outline:1px solid rgba(201,168,76,0.6);font-family:'Exo 2',sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;position:relative;overflow:hidden}
.cookie-btn-accept span{background:linear-gradient(180deg,#fff5c0,#c9a84c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.cookie-btn-decline{padding:9px 16px;border-radius:8px;cursor:pointer;background:transparent;border:1px solid rgba(255,255,255,0.08);font-family:'Exo 2',sans-serif;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#4a4d5a}
.cookie-btn-decline:hover{color:#8a8d9a}
@media(max-width:768px){
.cookie-banner{padding:14px 16px;flex-direction:column;align-items:flex-start}
.cookie-btns{width:100%}
.cookie-btn-accept,.cookie-btn-decline{flex:1;text-align:center}
.logo-pro-tag{font-size:7px;padding:2px 7px}
}

/* HERO */
.hero{position:relative;z-index:1;text-align:center;padding:60px 40px 40px;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(212,165,40,.08) 0%,transparent 70%);pointer-events:none}

.header-container{text-align:center;margin-bottom:40px}

.main-title-gold{
    font-family:'Cinzel',serif;
    font-size:80px;
    font-weight:800;
    text-transform:uppercase;
    letter-spacing:6px;
    margin:0;
    line-height:1.1;
    background:linear-gradient(180deg,#BF953F 0%,#FCF6BA 25%,#B38728 50%,#FBF5B7 75%,#AA771C 100%);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    text-shadow:0px 4px 15px rgba(0,0,0,.6);
    animation:title-in 1s ease-out;
}

/* ---- BOLD SUBTITLE ---- */
.subtitle-gold{
    font-family:'Rajdhani',sans-serif;
    font-size:32px;
    font-weight:700;
    font-style:italic;
    margin-top:15px;
    letter-spacing:3px;
    text-transform:uppercase;
    background:linear-gradient(90deg,#c8960c,#f5d060,#fff5c0,#f5d060,#c8960c);
    background-size:200% auto;
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    background-clip:text;
    animation:title-in 1s ease-out .2s both, subtitle-shine 4s linear 1.2s infinite;
    -webkit-text-stroke:0.4px rgba(200,150,12,0.3);
}

@keyframes subtitle-shine{
    0%{background-position:0% center}
    100%{background-position:200% center}
}

@keyframes title-in{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

/* STATUS BAR */
.status-bar{display:flex;justify-content:center;gap:40px;padding:16px;margin:0 auto;max-width:800px;animation:title-in 1s ease-out .4s both}
.status-item{display:flex;align-items:center;gap:8px;font-family:'Exo 2',sans-serif;font-size:13px;color:var(--text2)}
.status-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:blink 2s ease-in-out infinite}
.status-dot.gold{background:var(--gold);animation:blink 3s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* TABS */
.tabs{display:flex;justify-content:center;gap:0;margin:24px auto;max-width:700px;background:var(--bg2);border-radius:12px;border:1px solid rgba(212,165,40,.1);overflow:hidden;position:relative;z-index:1}
.tab{flex:1;padding:16px 24px;text-align:center;font-family:'Exo 2',sans-serif;font-size:14px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);cursor:pointer;transition:var(--transition);position:relative;display:flex;align-items:center;justify-content:center;gap:10px}
.tab:hover{color:var(--text);background:rgba(212,165,40,.05)}
.tab.active{color:var(--gold);background:rgba(212,165,40,.08)}
.tab.active::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold3),var(--gold2),var(--gold3))}
.tab-icon{font-size:18px}

/* MAIN CONTENT */
main{position:relative;z-index:1;max-width:1400px;margin:0 auto;padding:24px 24px 80px}

.matches-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:24px;margin-bottom:40px}

.match-card{background:linear-gradient(145deg,var(--bg2),var(--bg3));border:1px solid rgba(212,165,40,.1);border-radius:var(--card-radius);padding:0;overflow:hidden;transition:var(--transition);cursor:pointer;position:relative;animation:card-in .6s ease-out both}
.match-card:nth-child(1){animation-delay:.1s}
.match-card:nth-child(2){animation-delay:.2s}
.match-card:nth-child(3){animation-delay:.3s}
.match-card:nth-child(4){animation-delay:.4s}
.match-card:nth-child(5){animation-delay:.5s}
.match-card:nth-child(6){animation-delay:.6s}
@keyframes card-in{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.match-card:hover{border-color:rgba(212,165,40,.3);transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.4),0 0 30px rgba(212,165,40,.06)}

.card-header{display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-bottom:1px solid rgba(255,255,255,.04);background:rgba(212,165,40,.03)}
.league-badge{font-family:'Exo 2',sans-serif;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:6px}
.league-badge::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--gold)}
.live-badge{font-family:'Exo 2',sans-serif;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--green);padding:3px 10px;border:1px solid rgba(34,197,94,.3);border-radius:20px;background:rgba(34,197,94,.08);display:flex;align-items:center;gap:6px}
.live-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 1.5s ease-in-out infinite}

.teams-section{padding:20px 24px}
.team-row{display:flex;align-items:center;justify-content:space-between;gap:12px}
.team{display:flex;align-items:center;gap:14px;flex:1}
.team-crest{width:44px;height:44px;border-radius:10px;background:var(--bg4);display:flex;align-items:center;justify-content:center;font-size:20px;border:1px solid rgba(255,255,255,.06)}
.team-info h3{font-family:'Rajdhani',sans-serif;font-size:17px;font-weight:600;color:var(--text);line-height:1.2}
.team-info span{font-size:12px;color:var(--text3);font-weight:400}

.vs-badge{font-family:'Orbitron',sans-serif;font-size:11px;color:var(--gold);font-weight:700;padding:6px 12px;border:1px solid rgba(212,165,40,.2);border-radius:8px;background:rgba(212,165,40,.05);letter-spacing:2px}
.match-time{font-family:'Orbitron',sans-serif;font-size:13px;color:var(--gold2);text-align:center;margin-top:4px;letter-spacing:1px}

.odds-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:0 24px 16px}
.odd-btn{text-align:center;padding:10px 8px;background:rgba(212,165,40,.06);border:1px solid rgba(212,165,40,.1);border-radius:10px;cursor:pointer;transition:var(--transition)}
.odd-btn:hover{background:rgba(212,165,40,.15);border-color:rgba(212,165,40,.3)}
.odd-btn .label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:2px}
.odd-btn .value{font-family:'Orbitron',sans-serif;font-size:16px;font-weight:700;color:var(--gold2)}

.stats-row{display:flex;justify-content:space-around;padding:12px 24px;border-top:1px solid rgba(255,255,255,.04);background:rgba(0,0,0,.15)}
